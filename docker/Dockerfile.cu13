# CUDA 13 + vLLM + TRL GRPOTrainer (alternative container)
# Use this for standard TRL GRPO workflow. NOT the default.
# Build: docker compose -f docker-compose.yml -f docker/docker-compose.grpo.yml build
FROM nvidia/cuda:13.0.0-devel-ubuntu24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHON_VERSION=3.12

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.12 python3.12-venv python3-pip git curl wget build-essential \
    && rm -rf /var/lib/apt/lists/*

# Set up Virtual Env
RUN python3.12 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
RUN pip install --no-cache-dir --upgrade pip setuptools wheel

# Install PyTorch 2.11.0 with CUDA 13 support (required by vLLM)
RUN pip install --no-cache-dir torch torchaudio torchvision \
    --index-url https://download.pytorch.org/whl/cu130

# Install vLLM (pulls in CUDA 13 torch, TRL-compatible)
RUN pip install --no-cache-dir vllm

# Install Unsloth + ML Stack
RUN pip install --no-cache-dir \
    unsloth \
    transformers \
    datasets \
    peft \
    accelerate \
    bitsandbytes \
    sentencepiece \
    wandb \
    pytest \
    trl

WORKDIR /app

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD python -c "import torch; exit(0 if torch.cuda.is_available() else 1)"

CMD ["bash"]
